# Copy to .env and fill in. Never commit .env to git.

# --- ALWAYS REQUIRED ---
GEMINI_API_KEY=                      # Free: https://aistudio.google.com/apikey
PEXELS_API_KEY=                      # Free: https://www.pexels.com/api/

# --- TRANSCRIPTION — pick one, matching config.json -> transcribe_provider ---
# Option A: Groq (free, good for most Hebrew content)
GROQ_API_KEY=                        # Free: https://console.groq.com/keys
# Option B: ElevenLabs (paid ~$5/mo — higher Hebrew accuracy)
ELEVENLABS_API_KEY=                  # https://elevenlabs.io/app/settings/api-keys

# --- OPTIONAL ---
RUNWARE_API_KEY=                     # Free tier: https://runware.ai (AI image generation)

# --- SENDER: pick one ---
# Options: green-api | openclaw | skip (default)
SENDER=skip

# If SENDER=green-api:
GREEN_API_URL=https://7103.api.greenapi.com
GREEN_API_INSTANCE=
GREEN_API_TOKEN=

# If SENDER=openclaw: no env vars — uses `openclaw message send` binary
