# Copy to .env and fill in. Never commit .env to git.

# --- REQUIRED ---
GEMINI_API_KEY=
ELEVENLABS_API_KEY=

# --- AT LEAST ONE REQUIRED for B-roll clips ---
PEXELS_API_KEY=              # Free: https://www.pexels.com/api/
RUNWARE_API_KEY=             # Free tier: https://runware.ai (AI image generation)

# --- SENDER: pick one ---
# Options: green-api | openclaw | skip
SENDER=skip

# If SENDER=green-api:
GREEN_API_URL=https://7103.api.greenapi.com
GREEN_API_INSTANCE=
GREEN_API_TOKEN=

# If SENDER=openclaw: no vars needed — uses `openclaw message send` binary
